  "private": true,
  "scripts": {
    "build": "next build",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv env.d.ts",
    "check": "npm run build && tsc",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "dev": "next dev",
    "lint": "next lint",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "start": "next start",
    "db:migrate": "wrangler d1 execute menu-org-tr-db --local --file=migrations/0000_mighty_cerebro.sql",
    "db:seed": "wrangler d1 execute menu-org-tr-db --local --file=migrations/seed_local.sql",
    "db:migrate:remote": "wrangler d1 execute menu-org-tr-db --remote --file=migrations/0000_mighty_cerebro.sql",
    "create-user": "node scripts/create-user.mjs",
    "create-user:remote": "DB_ENV=remote node scripts/create-user.mjs"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}